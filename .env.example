# Supabase — Dashboard → Project Settings → API. Copy this file to .env and fill in.
# .env is gitignored. Never commit real keys.

SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# anon/public key — safe to ship in the app/client (RLS protects the data)
SUPABASE_ANON_KEY=your-anon-public-key

# service_role key — FULL POWER, BYPASSES RLS. SERVER ONLY.
# Never put this in the mobile/web client and never commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Geoapify Static Maps (free OpenStreetMap tier) — https://geoapify.com. Server-only.
# When set, the API adds a live map image URL to the deal detail during a meetup.
GEOAPIFY_KEY=your-geoapify-key
